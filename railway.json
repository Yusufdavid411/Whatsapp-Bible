{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/health"
  },
  "volumes": [
    {
      "name": "whatsapp-session",
      "mountPath": "/app/.wwebjs_auth"
    },
    {
      "name": "database",
      "mountPath": "/app/data"
    }
  ]
}
